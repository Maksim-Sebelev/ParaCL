func() : foo {{{{{{{{666;}}}}}}}}
print "foo() = ", foo();

func(x) : foo {{{{{{{{{{{{{{{{{{{{{{{x;}}}}}}}}}}}}}}}}}}}}}}}
arg = -666;
print "func(", arg, ") = ", arg;

func(x, y) : foo {{{{{{{{{{{{{{{{{{{{{{ {x;} {y;} {x; y; x+y;}}}}}}}}}}}}}}}}}}}}}}}
x = y = 333;
print "foo(",x,", ",y,") = ", foo(x, y);

